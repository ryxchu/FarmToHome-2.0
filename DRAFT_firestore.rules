rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // 2. Entity Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'fullName']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['buyer', 'farmer', 'admin'] &&
             data.fullName is string && data.fullName.size() <= 100 &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 20)) &&
             (!('status' in data) || (data.status in ['verified', 'unverified']));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'farmerId', 'stock']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is int && data.stock >= 0 &&
             data.farmerId == request.auth.uid;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'buyerId', 'farmerId', 'items', 'total', 'status']) &&
             data.buyerId == request.auth.uid &&
             data.status in ['pending', 'accepted', 'preparing', 'shipped', 'delivered', 'cancelled'] &&
             data.total is number && data.total >= 0 &&
             data.items is list && data.items.size() > 0;
    }

    // 3. Collection Rules

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'phone', 'status', 'farmName', 'farmAddress', 'farmStory', 'farmingMethods', 'certifications', 'rewardsPoints', 'ecoMetrics']);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidProduct(incoming()) && isValidId(productId) && productId == incoming().id;
      allow update: if isSignedIn() && (
        (incoming().farmerId == request.auth.uid && incoming().farmerId == existing().farmerId && (
          // Farmer updating product details
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'category', 'unit', 'stock', 'images', 'harvestDate', 'isPublished'])
        )) ||
        // Buyer reducing stock when ordering (this usually needs a cloud function or atomic write, but for simple client updates):
        (incoming().diff(existing()).affectedKeys().hasOnly(['stock']) && incoming().stock < existing().stock)
      );
      allow delete: if isSignedIn() && existing().farmerId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (existing().buyerId == request.auth.uid || existing().farmerId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.farmerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming()) && isValidId(orderId) && orderId == incoming().id;
      allow update: if isSignedIn() && (
        // Buyer cancelling
        (isOwner(existing().buyerId) && incoming().status == 'cancelled' && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        // Farmer updating status
        (isOwner(existing().farmerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'riderLocation', 'eta', 'updatedAt']))
      );
    }

    match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && incoming().buyerId == request.auth.uid;
    }

    match /posts/{postId} {
        allow read: if true;
        allow create, update: if isSignedIn() && incoming().farmerId == request.auth.uid;
        allow delete: if isSignedIn() && existing().farmerId == request.auth.uid;
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
    }
  }
}
