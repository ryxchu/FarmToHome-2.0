rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isHardcodedAdmin() {
      return isSignedIn() && request.auth.token.email.matches('(?i)ryzabasas16@gmail\\.com');
    }

    function isAdmin() { 
      return isHardcodedAdmin() || (
             isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // 2. Entity Validators
    function isValidUser(data) {
      return (data.keys().hasAll(['uid', 'email', 'role', 'fullName']) || !isSignedIn()) &&
             (!('role' in data) || (
               (data.role in ['buyer', 'farmer']) || 
               (data.role == 'admin' && (isHardcodedAdmin() || isAdmin()))
             )) &&
             (!('fullName' in data) || (data.fullName is string && data.fullName.size() <= 100)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 20)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 500)) &&
             (!('status' in data) || (data.status in ['verified', 'unverified', 'pending', 'banned'])) &&
             (!('coordinates' in data) || (data.coordinates is map || data.coordinates == null)) &&
             (!('photoURL' in data) || (data.photoURL is string)) &&
             (!('primaryCrops' in data) || (data.primaryCrops is string && data.primaryCrops.size() <= 1000)) &&
             (!('contactNumber' in data) || (data.contactNumber is string && data.contactNumber.size() <= 50)) &&
             (!('deliveryAddress' in data) || (data.deliveryAddress is string && data.deliveryAddress.size() <= 1000)) &&
             (!('uid' in data) || (data.uid == request.auth.uid || isAdmin()));
    }

    function isValidProduct(data) {
      return (!('id' in data) || (data.id is string && data.id.size() <= 128)) &&
             (!('name' in data) || (data.name is string && data.name.size() <= 200)) &&
             (!('price' in data) || (data.price is number && data.price >= 0)) &&
             (!('stock' in data) || (data.stock is number && data.stock >= 0)) &&
             (!('coordinates' in data) || (data.coordinates is map || data.coordinates == null)) &&
             (!('farmerId' in data) || (data.farmerId == request.auth.uid || isAdmin()));
    }

    function isValidOrder(data) {
      return (!('id' in data) || (data.id is string)) &&
             (!('buyerId' in data) || (data.buyerId == request.auth.uid || isAdmin())) &&
             (!('status' in data) || (data.status in ['pending', 'accepted', 'preparing', 'shipped', 'delivered', 'cancelled'])) &&
             (!('total' in data) || (data.total is number && data.total >= 0)) &&
             (!('discount' in data) || (data.discount is number)) &&
             (!('discountType' in data) || (data.discountType is string || data.discountType == null)) &&
             (!('items' in data) || (data.items is list && data.items.size() > 0));
    }

    function isValidReview(data) {
      return (!('productId' in data) || (data.productId is string)) &&
             (!('buyerId' in data) || (data.buyerId == request.auth.uid)) &&
             (!('rating' in data) || (data.rating is number && data.rating >= 1 && data.rating <= 5));
    }

    function isValidConversation(data) {
      return (!('id' in data) || (data.id is string)) &&
             (!('participants' in data) || (data.participants is list && data.participants.size() == 2 && request.auth.uid in data.participants)) &&
             (!('buyerId' in data) || !('farmerId' in data) || (data.buyerId == request.auth.uid || data.farmerId == request.auth.uid || isAdmin())) &&
             (!('lastMessage' in data) || (data.lastMessage is string));
    }

    function isValidMessage(data) {
      return (!('id' in data) || (data.id is string)) &&
             (!('senderId' in data) || (data.senderId == request.auth.uid)) &&
             (!('content' in data) || (data.content is string && data.content.size() <= 2000));
    }

    function isValidNotification(data) {
      return (!('id' in data) || (data.id is string)) &&
             (!('userId' in data) || (data.userId is string)) &&
             (!('title' in data) || (data.title is string && data.title.size() <= 200)) &&
             (!('message' in data) || (data.message is string && data.message.size() <= 1000)) &&
             (!('type' in data) || (data.type in ['order', 'message', 'system']));
    }

    function isBanned() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'banned';
    }

    match /users/{userId} {
      allow get: if true; // Public profiles are viewable by everyone
      allow list: if isSignedIn() && (
        resource.data.role == 'farmer' || 
        resource.data.uid == request.auth.uid || 
        isHardcodedAdmin() || 
        isAdmin()
      );
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == request.auth.uid;
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && 
                    (isAdmin() || (incoming().uid == existing().uid && incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'phone', 'address', 'photoURL', 'status', 'farmName', 'farmAddress', 'farmStory', 'farmingMethods', 'certifications', 'rewardsPoints', 'ecoMetrics', 'isApproved', 'coordinates', 'primaryCrops', 'contactNumber', 'deliveryAddress'])));
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && !isBanned() && isValidProduct(incoming()) && isValidId(productId) && productId == incoming().id;
      allow update: if isSignedIn() && !isBanned() && (
        isAdmin() ||
        (isOwner(existing().farmerId) && isValidProduct(incoming()) && incoming().farmerId == existing().farmerId && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'category', 'unit', 'stock', 'images', 'harvestDate', 'isPublished', 'rating', 'reviewCount', 'approvalStatus', 'isFeatured', 'updatedAt', 'coordinates'])
        )) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['stock', 'rating', 'reviewCount']))
      );
      allow delete: if isSignedIn() && (isOwner(existing().farmerId) || isAdmin());
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && isValidId(orderId) && (existing().buyerId == request.auth.uid || existing().farmerId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.farmerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming()) && isValidId(orderId) && orderId == incoming().id;
      allow update: if isSignedIn() && (
        isAdmin() || (
          // Buyer-triggered Updates
          isOwner(existing().buyerId) && (
            // A. Buyer cancels the order (allowed keys: status, updatedAt, cancellationReason)
            (incoming().status == 'cancelled' && 
             incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'cancellationReason']) &&
             existing().status != 'delivered' && existing().status != 'cancelled') ||
            
            // B. Buyer confirms delivery receipt (allowed keys: status, updatedAt)
            (incoming().status == 'delivered' && 
             incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
             existing().status != 'delivered' && existing().status != 'cancelled') ||
            
            // C. Buyer rates a delivered order (allowed keys: hasRated, updatedAt)
            (existing().status == 'delivered' && 
             incoming().diff(existing()).affectedKeys().hasOnly(['hasRated', 'updatedAt']))
          )
        ) || (
          // Farmer-triggered Updates (allowed keys: status, riderLocation, eta, updatedAt, cancellationReason, paymentStatus)
          isOwner(existing().farmerId) && 
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'riderLocation', 'eta', 'updatedAt', 'cancellationReason', 'paymentStatus'])
        )
      );
    }

    match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidId(reviewId) && isValidReview(incoming());
    }

    match /posts/{postId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidId(postId) && incoming().farmerId == request.auth.uid;
        allow update: if isSignedIn() && (
          isAdmin() ||
          (isOwner(existing().farmerId) && incoming().farmerId == existing().farmerId) ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'comments', 'sharesCount']))
        );
        allow delete: if isSignedIn() && (isOwner(existing().farmerId) || isAdmin());
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
    }

    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    // 4. Messaging Rules
    match /conversations/{conversationId} {
      allow get: if isSignedIn() && (resource == null || request.auth.uid in resource.data.participants || isAdmin());
      allow list: if isSignedIn() && (request.auth.uid in resource.data.participants || isAdmin());
      allow create: if isSignedIn() && isValidConversation(incoming()) && isValidId(conversationId) && conversationId == incoming().id;
      allow update: if isSignedIn() && (request.auth.uid in existing().participants || isAdmin()) && 
                    incoming().participants == existing().participants &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['lastMessage', 'lastMessageAt', 'updatedAt']);
    }

    match /conversations/{conversationId}/messages/{messageId} {
      allow read: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants || isAdmin());
      allow create: if isSignedIn() && isValidMessage(incoming()) && isValidId(messageId) && messageId == incoming().id &&
                    request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isSignedIn() && isValidId(notificationId) && incoming().id == notificationId && isValidNotification(incoming());
      allow update: if isSignedIn() && (isOwner(existing().userId) || isAdmin()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
    }
  }
}
