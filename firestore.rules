rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isHardcodedAdmin() {
      return isSignedIn() && request.auth.token.email.matches('(?i)ryzabasas16@gmail\\.com');
    }

    function isAdmin() { 
      return isHardcodedAdmin() || (
             isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // 2. Entity Validators
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'fullName']) &&
             data.role in ['buyer', 'farmer', 'admin'] &&
             data.fullName is string && data.fullName.size() <= 100 &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 20)) &&
             (!('address' in data) || (data.address is string && data.address.size() <= 500)) &&
             (!('status' in data) || (data.status in ['verified', 'unverified', 'pending', 'banned'])) &&
             (!('createdAt' in data) || (data.createdAt is string));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'price', 'farmerId', 'stock']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0 &&
             (isAdmin() || data.farmerId == request.auth.uid);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'buyerId', 'farmerId', 'items', 'total', 'status']) &&
             data.id is string &&
             (isAdmin() || data.buyerId == request.auth.uid) &&
             data.status in ['pending', 'accepted', 'preparing', 'shipped', 'delivered', 'cancelled'] &&
             data.total is number && data.total >= 0 &&
             data.items is list && data.items.size() > 0;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productId', 'buyerId', 'rating', 'orderId']) &&
             data.buyerId == request.auth.uid &&
             data.rating is number && data.rating >= 1 && data.rating <= 5;
    }

    // 3. Collection Rules

    function isBanned() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'banned';
    }

    match /users/{userId} {
      allow get: if true; // Public profiles are viewable by everyone
      allow list: if isHardcodedAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == request.auth.uid;
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && 
                    (isAdmin() || (incoming().uid == existing().uid && incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'phone', 'address', 'photoURL', 'status', 'farmName', 'farmAddress', 'farmStory', 'farmingMethods', 'certifications', 'rewardsPoints', 'ecoMetrics', 'isApproved'])));
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && !isBanned() && isValidProduct(incoming()) && isValidId(productId) && productId == incoming().id;
      allow update: if isSignedIn() && !isBanned() && (
        isAdmin() ||
        (isOwner(existing().farmerId) && isValidProduct(incoming()) && incoming().farmerId == existing().farmerId && (
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'category', 'unit', 'stock', 'images', 'harvestDate', 'isPublished', 'rating', 'reviewCount', 'approvalStatus', 'isFeatured', 'updatedAt'])
        )) ||
        (incoming().diff(existing()).affectedKeys().hasOnly(['stock', 'rating', 'reviewCount']))
      );
      allow delete: if isSignedIn() && (isOwner(existing().farmerId) || isAdmin());
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && isValidId(orderId) && (existing().buyerId == request.auth.uid || existing().farmerId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.farmerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming()) && isValidId(orderId) && orderId == incoming().id;
      allow update: if isSignedIn() && (
        isAdmin() || (
          ( (isOwner(existing().buyerId) && incoming().status == 'cancelled' && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
            (isOwner(existing().farmerId) && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'riderLocation', 'eta', 'updatedAt']))
          ) && (existing().status != 'delivered' && existing().status != 'cancelled')
        )
      );
    }

    match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidId(reviewId) && isValidReview(incoming());
    }

    match /posts/{postId} {
        allow read: if true;
        allow create: if isSignedIn() && isValidId(postId) && incoming().farmerId == request.auth.uid;
        allow update: if isSignedIn() && isOwner(existing().farmerId) && incoming().farmerId == existing().farmerId;
        allow delete: if isSignedIn() && isOwner(existing().farmerId);
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
    }

    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }
  }
}
